  ScriptText_name: {fileID: 284055873}
  dialogue:
  - "\uB2F9\uC2E0\uC778 \uAC83\uC778\uAC00\uC694."
  - "\uAE30\uB2E4\uB9AC\uACE0 \uC788\uB358 \uAC83\uC774\uC5D0\uC694."
  - "\uADF8\uCABD\uC774 \uC124\uB9C8...."
  - "\uC608. \uD638\uBC15\uC9D1 \uC5C4\uC9C0 \uC81C\uC790\uC778 \uB8E8\uCE58\uD554\uC774\uC778
    \uAC83\uC774\uC5D0\uC694."
  - "\uAC01\uC624\uD558\uB294 \uAC83\uC774\uC5D0\uC694. 1\uB3001 \uACB0\uD22C\uC5D0\uC11C\uB294
    \uD314\uB808\uB974\uBAA8\uB97C \uC775\uD78C \uC81C\uAC00 \uC720\uB9AC\uD55C \uAC83\uC774\uC5D0\uC694."
  speaker:
  - "\uC5C4\uC9C0 \uC81C\uC790?"
  - "\uC5C4\uC9C0 \uC81C\uC790?"
  - "\uC8FC\uD64D\uD638\uBC15"
  - "\uB8E8\uCE58\uD554\uC774"
  - "\uB8E8\uCE58\uD554\uC774"
  typingSpeed: 0.05
