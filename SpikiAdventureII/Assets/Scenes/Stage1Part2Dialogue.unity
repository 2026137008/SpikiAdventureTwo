  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ToriStart
  chuchu: {fileID: 596249311}
  tori: {fileID: 2140077068}
  ScriptText_dialogue: {fileID: 1807151675}
  ScriptText_name: {fileID: 1288468608}
  dialogue:
  - "\uD558\uC544.... \uB8E8\uCE58\uD554\uC774."
  - "\uC81C\uAC00 \uBA87\uBC88\uC774\uB098 \uB9D0\uD55C \uAC83\uC774\uC5D0\uC694."
  - "\uADF8\uB534 \uBD80\uC704 \uC2E0\uACBD \uB044\uACE0,"
  - "\uC2EC\uC7A5\uC744 \uB178\uB9AC\uB77C\uACE0 \uD588\uC796\uC544\uC694, \uC2EC\uC7A5\uC744!!"
  - ....
  - "\uC8C4\uC1A1\uD55C \uAC83\uC774\uC5D0\uC694, \uC2A4\uC2B9\uB2D8."
  - "\uC800\uB9AC \uAEBC\uC838 \uC788\uC73C\uC138\uC694. \uC81C\uAC00 \uD574\uACB0\uD558\uB294
    \uAC8C \uCC28\uB77C\uB9AC \uB0AB\uACA0\uB124\uC694."
  - "\uC5C4\uC9C0\uC758 \uC5B8\uB354\uBCF4\uC2A4(\uC600\uB358), \uB098 \uBC1C\uB80C\uD554\uC774\uAC00
    \uCC98\uB9AC\uD558\uB294 \uAC83\uC774\uC5D0\uC694!"
  speaker:
  - "\uC5C4\uC9C0 \uC544\uBE44?"
  - "\uC5C4\uC9C0 \uC544\uBE44?"
  - "\uC5C4\uC9C0 \uC544\uBE44?"
  - "\uC5C4\uC9C0 \uC544\uBE44?"
  - "\uB8E8\uCE58\uD554\uC774"
  - "\uB8E8\uCE58\uD554\uC774"
  - "\uC5C4\uC9C0 \uC544\uBE44?"
  - "\uBC1C\uB80C\uD554\uC774"
  typingSpeed: 0.05
  audioSource: {fileID: 1353609713}
  textSound: {fileID: 8300000, guid: b031e79d359ed4a1bbf6f3652ca393ac, type: 3}
